{
  "name": "vantage-terminal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\"",
    "seed:intel": "npx tsx scripts/seed-intel-data.ts",
    "index:bootstrap": "npx tsx scripts/bootstrap-opensearch-index.ts",
    "index:docs": "npx tsx scripts/index-documents-opensearch.ts",
    "sync:graph": "npx tsx scripts/sync-graph-neo4j.ts",
    "validate:synthetic": "npx tsx scripts/validate-synthetic-depth.ts",
    "docs:generate": "npx tsx docs/user-guide/scripts/generate-content.mjs",
    "docs:build": "npm run docs:generate && npx vitepress build docs/user-guide/src",
    "docs:preview": "npx vitepress preview docs/user-guide/src --outDir ../site",
    "docs:dev": "npx vitepress dev docs/user-guide/src",
    "docs:screenshots": "node docs/user-guide/scripts/gen-placeholders.cjs && npx tsx docs/user-guide/scripts/screenshots.mjs",
    "docs:screenshots:live": "node docs/user-guide/scripts/screenshots.mjs",
    "docs:pdf": "npx tsx docs/user-guide/scripts/export-pdf.mjs",
    "docs:verify": "npx tsx docs/user-guide/scripts/verify.mjs",
    "docs:all": "npm run docs:build && npm run docs:screenshots && npm run docs:pdf && npm run docs:verify",
    "docs:guide": "npx tsx scripts/generate-html-guide.mjs",
    "mnemonic:smoke": "npx tsx scripts/mnemonic-catalog-smoke.ts",
    "mnemonic:integration-smoke": "npx tsx scripts/mnemonic-integration-smoke.ts",
    "mnemonic:navtree-routing-smoke": "npx tsx scripts/navtree-routing-smoke.ts"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-virtual": "^3.13.21",
    "autoprefixer": "^10.4.21",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.553.0",
    "maplibre-gl": "^5.19.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "openai": "^6.25.0",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-map-gl": "^8.1.0",
    "react-resizable-panels": "^4.7.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.3.1",
    "yahoo-finance2": "^3.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitepress": "^1.6.4"
  }
}

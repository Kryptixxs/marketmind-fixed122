# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# FINNHUB: Real-time US stock WebSocket + REST API. Free at https://finnhub.io
# Used for real-time equity prices and fundamentals.
NEXT_PUBLIC_FINNHUB_KEY=""
FINNHUB_API_KEY=""

# FRED: Federal Reserve Economic Data. Free at https://fred.stlouisfed.org/docs/api/api_key.html
# Used for macroeconomic indicators (GDP, CPI, unemployment, rates, etc.)
FRED_API_KEY=""

# FMP_API_KEY: For accurate economic calendar (real dates/events). Free at https://site.financialmodelingprep.com/developer/docs
# If not set, a fallback source is used (may have incorrect dates).
FMP_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
